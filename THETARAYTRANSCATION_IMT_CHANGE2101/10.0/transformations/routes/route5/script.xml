        <ns1:MOBILENUMBER>
          <xsl:value-of select="$document_OUT_PORT/ns1:Result/ns1:row/ns1:MOBILENUMBER"></xsl:value-of>
        </ns1:MOBILENUMBER>
        <ns1:ADRESSE>
          <xsl:value-of select="$document_OUT_PORT/ns1:Result/ns1:row/ns1:ADRESSE"></xsl:value-of>
        </ns1:ADRESSE>
        <ns1:NATIONALITY>
          <xsl:value-of select="$document_OUT_PORT/ns1:Result/ns1:row/ns1:NATIONALITY"></xsl:value-of>
        </ns1:NATIONALITY>
        <ns1:GENDER>
          <xsl:value-of select="$document_OUT_PORT/ns1:Result/ns1:row/ns1:GENDER"></xsl:value-of>
        </ns1:GENDER>
        <ns1:PLACEOFBIRTH>
          <xsl:value-of select="$document_OUT_PORT/ns1:Result/ns1:row/ns1:PLACEOFBIRTH"></xsl:value-of>
        </ns1:PLACEOFBIRTH>
        <ns1:DATE_OF_BIRTH>
          <xsl:value-of select="substring($document_OUT_PORT/ns1:Result/ns1:row/ns1:DATE_OF_BIRTH,'1','10')"></xsl:value-of>
        </ns1:DATE_OF_BIRTH>
        <ns1:DESTACCOUNT>
          <xsl:value-of select="$document_OUT_PORT/ns1:Result/ns1:row/ns1:DESTACCOUNT"></xsl:value-of>
