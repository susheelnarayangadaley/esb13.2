        <ns1:WALLETCURRENCY>
          <xsl:value-of select="$document_OUT_PORT/ns1:Result/ns1:row/ns1:WALLETCURRENCY"></xsl:value-of>
        </ns1:WALLETCURRENCY>
        <ns1:TRANSDATETIME>
          <xsl:value-of select="$document_OUT_PORT/ns1:Result/ns1:row/ns1:TRANSDATETIME"></xsl:value-of>
        </ns1:TRANSDATETIME>
        <ns1:RESPCODE>
          <xsl:value-of select="$document_OUT_PORT/ns1:Result/ns1:row/ns1:RESPCODE"></xsl:value-of>
        </ns1:RESPCODE>
        <ns1:USERID>
          <xsl:value-of select="$document_OUT_PORT/ns1:Result/ns1:row/ns1:USERID"></xsl:value-of>
        </ns1:USERID>
        <ns1:FULLNAME>
          <xsl:value-of select="$document_OUT_PORT/ns1:Result/ns1:row/ns1:FULLNAME"></xsl:value-of>
        </ns1:FULLNAME>
        <ns1:DATE_TRANS>
