        </ns1:DATE_TRANS>
        <ns1:DESTUSERID>
          <xsl:value-of disable-output-escaping="no" select="$document_OUT_PORT/ns1:Result/ns1:row/ns1:DESTUSERID"></xsl:value-of>
        </ns1:DESTUSERID>
        <ns1:DESTADDRESS>
          <xsl:value-of disable-output-escaping="no" select="$document_OUT_PORT/ns1:Result/ns1:row/ns1:DESTADDRESS"></xsl:value-of>
        </ns1:DESTADDRESS>
        <ns1:DESTFIRSTNAME>
          <xsl:value-of disable-output-escaping="no" select="$document_OUT_PORT/ns1:Result/ns1:row/ns1:DESTFIRSTNAME"></xsl:value-of>
        </ns1:DESTFIRSTNAME>
        <ns1:DESTMERCHANTNAME>
          <xsl:value-of disable-output-escaping="no" select="$document_OUT_PORT/ns1:Result/ns1:row/ns1:DESTMERCHANTNAME"></xsl:value-of>
