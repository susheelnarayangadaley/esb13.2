        <ns1:DESTCUSTOMERNAME>
          <xsl:value-of disable-output-escaping="no" select="$document_OUT_PORT/ns1:Result/ns1:row/ns1:DESTCUSTOMERNAME"></xsl:value-of>
        </ns1:DESTCUSTOMERNAME>
        <ns1:NATIONALITY_CODE>
          <xsl:value-of disable-output-escaping="no" select="$document_OUT_PORT/ns1:Result/ns1:row/ns1:NATIONALITY_CODE"></xsl:value-of>
        </ns1:NATIONALITY_CODE>
        <ns1:CITY>
          <xsl:value-of select="$document_OUT_PORT/ns1:Result/ns1:row/ns1:CITY"></xsl:value-of>
        </ns1:CITY>
      </ns1:row>
    </ns1:Result>
  </xsl:template>
</xsl:stylesheet>