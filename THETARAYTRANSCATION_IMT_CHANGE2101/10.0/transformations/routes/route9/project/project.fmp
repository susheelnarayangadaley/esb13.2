  <mappermodel:Extensions>
    <mappermodel:Extension language="javascript" name="thetaray_trans">
      <mappermodel:Script>function convertToYYYYMMDDHH24MISS_minus1(input) {&#xD;
&#xD;
    if (!input || typeof input !== &quot;string&quot;) {&#xD;
&#xD;
        throw new Error(&quot;Invalid input: expected non-empty string in format YYYY-MM-DDTHH:MI:SS±HH:MM00000&quot;);&#xD;
&#xD;
    }&#xD;
 &#xD;
    // Trim and remove trailing &quot;00000&quot; if present&#xD;
&#xD;
    var raw = input.trim();&#xD;
&#xD;
    var clean = raw.replace(/00000$/, &quot;&quot;);&#xD;
 &#xD;
    // Extract timezone like &quot;+05:30&quot; or &quot;-04:00&quot;&#xD;
&#xD;
    var tzMatch = clean.match(/([+\-]\d{2}:\d{2})$/);&#xD;
&#xD;
    if (!tzMatch) {&#xD;
&#xD;
        tzMatch = clean.match(/([+\-]\d{2}:\d{2})/);&#xD;
&#xD;
    }&#xD;
&#xD;
    if (!tzMatch) {&#xD;
&#xD;
        throw new Error(&quot;Timezone not found in input: &quot; + input);&#xD;
&#xD;
    }&#xD;
&#xD;
    var tz = tzMatch[1];&#xD;
 &#xD;
    // Parse ISO string (let JS engine interpret timezone)&#xD;
&#xD;
    var parsedMs = Date.parse(clean);&#xD;
&#xD;
    if (isNaN(parsedMs)) {&#xD;
&#xD;
        throw new Error(&quot;Failed to parse date after cleaning: &quot; + clean);&#xD;
&#xD;
    }&#xD;
 &#xD;
    // Subtract exactly one day (24 * 60 * 60 * 1000)&#xD;
&#xD;
    var ONE_DAY_MS = 24 * 60 * 60 * 1000;&#xD;
&#xD;
    var newUtcMs = parsedMs - ONE_DAY_MS;&#xD;
 &#xD;
    // Compute timezone offset minutes from tz string&#xD;
&#xD;
    var sign = (tz.charAt(0) === &quot;-&quot;) ? -1 : 1;&#xD;
&#xD;
    var tzParts = tz.substring(1).split(&quot;:&quot;);&#xD;
&#xD;
    var tzH = parseInt(tzParts[0], 10);&#xD;
&#xD;
    var tzM = parseInt(tzParts[1], 10);&#xD;
&#xD;
    if (isNaN(tzH) || isNaN(tzM)) {&#xD;
&#xD;
        throw new Error(&quot;Invalid timezone format: &quot; + tz);&#xD;
&#xD;
    }&#xD;
&#xD;
    var offsetMinutes = sign * (tzH * 60 + tzM);&#xD;
 &#xD;
    // Convert the new UTC instant back to &quot;local fields&quot; in the original timezone:&#xD;
&#xD;
    // localMs = newUtcMs + offsetMinutes*60000&#xD;
&#xD;
    var localMs = newUtcMs + (offsetMinutes * 60000);&#xD;
&#xD;
    var outDate = new Date(localMs);&#xD;
 &#xD;
    // Helper pad&#xD;
&#xD;
    function pad(n) { n = String(n); return (n.length &lt; 2 ? &quot;0&quot; + n : n); }&#xD;
 &#xD;
    // Use UTC getters because we adjusted ms to represent the local fields&#xD;
&#xD;
    var outY = outDate.getUTCFullYear();&#xD;
&#xD;
    var outMo = outDate.getUTCMonth() + 1;&#xD;
&#xD;
    var outD = outDate.getUTCDate();&#xD;
&#xD;
    var outH = outDate.getUTCHours();&#xD;
&#xD;
    var outMin = outDate.getUTCMinutes();&#xD;
&#xD;
    var outS = outDate.getUTCSeconds();&#xD;
 &#xD;
    return String(outY) + pad(outMo) + pad(outD) + pad(outH) + pad(outMin) + pad(outS);&#xD;
&#xD;
}&#xD;
 </mappermodel:Script>
      <mappermodel:Function name="convertToYYYYMMDDHH24MISS_minus1" return="String">
        <mappermodel:Argument datatype="String" name="input"/>
      </mappermodel:Function>
    </mappermodel:Extension>
    <mappermodel:Extension language="javascript" name="thetaray">
      <mappermodel:Script>function convertToYYYYMMDDHH24MISS(input) {

  // Extract timezone part without the 00000
  var timezoneMatch = input.match(/([+\-]\d{2}:\d{2})/);
  if (!timezoneMatch) {
    throw &quot;Invalid input: timezone not found in +/-HH:MM00000 format.&quot;;
  }

  var tz = timezoneMatch[1];  // e.g. &quot;+05:30&quot;

  // Remove trailing &quot;00000&quot;
  var cleanInput = input.replace(/00000$/, &quot;&quot;);

  // ISO string is already correct once trimmed
  var isoString = cleanInput;

  // Create Date object
  var date = new Date(isoString);

  // Helper to pad numbers
  function pad(num) {
    num = String(num);
    return (num.length &lt; 2 ? &quot;0&quot; + num : num);
  }

  var YYYY = date.getFullYear();
  var MM = pad(date.getMonth() + 1);
  var DD = pad(date.getDate());
  var HH = pad(date.getHours());
  var MI = pad(date.getMinutes());
  var SS = pad(date.getSeconds());

  return &quot;&quot; + YYYY + MM + DD + HH + MI + SS;
}</mappermodel:Script>
      <mappermodel:Function name="convertToYYYYMMDDHH24MISS" return="String">
        <mappermodel:Argument datatype="String" name="input"/>
      </mappermodel:Function>
    </mappermodel:Extension>
  </mappermodel:Extensions>
  <mappermodel:UserXSL index="2" node="IN_PORT:0,COMPLEX:0,query:0">--></mappermodel:UserXSL>
  <mappermodel:UserXSL index="1" node="IN_PORT:0,COMPLEX:0,query:0">&lt;xsl:variable name=&quot;var0&quot;>select  id,servicename,amounttran/100,trancurrency,mobilenumber,(select homeaddress from wallet.cms_customer where user_id = userid)as adresse,(select nationality from wallet.cms_customer where user_id = userid)as nationality,(select gender from wallet.cms_customer where user_id = userid)as gender,(select nvl(placeofbirth,nationality) as placeofb from  wallet.cms_customer where user_id = userid) as placeofbirth, destaccount,nvl(DESTMOBILENUMBER,MOBILENUMBER)as DESTMOBILENUMBER,walletcurrency,TRANSDATETIME,respcode,userid,concat(firstname,lastname)as fullName ,substr(TRANSDATETIME,0,8) as date_trans,TO_CHAR(TO_DATE(transdatetime, 'YYYYMMDDHH24MISS'), 'YYYY-MM-DD') as date_trans,(select dateofbirth from wallet.cms_customer where user_id = userid)as date_of_birth,destuserid,destaddress,destfirstname,destmerchantname,destcustomername&#xD;
 &#xD;
,(select p.abbreviation as nationality from  wallet.fine_contact_country p where nationality = p.name)as nationality_code ,(select city from wallet.cms_customer where user_id = userid)as city&#xD;
 &#xD;
from WALLET.ws_log&#xD;
 &#xD;
WHERE servicename&#xD;
 &#xD;
     in (select service_name from wallet.transactioncodes where is_financial='1')  and&#xD;
 &#xD;
TRANSDATETIME BETWEEN '&lt;/xsl:variable>&#xD;
&lt;xsl:value-of select=&quot;$var0&quot;>&lt;/xsl:value-of>&#xD;
&lt;xsl:value-of select=&quot;thetaray_trans:convertToYYYYMMDDHH24MISS_minus1(string(datetime:dateTime()))&quot;>&lt;/xsl:value-of>&#xD;
&lt;xsl:variable name=&quot;var1&quot;>' AND '&lt;/xsl:variable>&#xD;
&lt;xsl:value-of select=&quot;$var1&quot;>&lt;/xsl:value-of>&#xD;
&lt;xsl:value-of select=&quot;thetaray:convertToYYYYMMDDHH24MISS(string(datetime:dateTime()))&quot;>&lt;/xsl:value-of>&#xD;
&lt;xsl:variable name=&quot;var2&quot;>'&lt;/xsl:variable>&#xD;
&lt;xsl:value-of select=&quot;$var2&quot;>&lt;/xsl:value-of>&#xD;
&lt;xsl:variable name=&quot;var3&quot;>and servicename not in ('InitSendMoneyInternational','SendMoneyInternational')&lt;/xsl:variable>&#xD;
&lt;xsl:value-of select=&quot;$var3&quot;>&lt;/xsl:value-of>&#xD;
&lt;!--</mappermodel:UserXSL>
</mappermodel:MapperProject>