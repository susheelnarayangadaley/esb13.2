  &lt;xsl:import href="GLOBAL_FUNCLET_PATH">&lt;/xsl:import>
  &lt;xsl:output method="xml" indent="yes" encoding="UTF-8" xalan:indent-amount="2" omit-xml-declaration="no">&lt;/xsl:output>
  &lt;xsl:variable name="document" select="/">&lt;/xsl:variable>
  &lt;xsl:variable name="document_Input1" select="document('Input1')">&lt;/xsl:variable>
  &lt;xsl:template match="/">
    &lt;ns2:Envelope>
      &lt;ns2:Body>
        &lt;ns15:BakongWalletTransfer>
          &lt;WebRequestCommon>
            &lt;company>
              &lt;xsl:variable name="if0">
                &lt;xsl:choose>
                  &lt;xsl:when test="(Md5UniCode:md5hashing.Md5hashing.getMD5HexencodedString(string(EnDe:aesencryptiondecryption.AESEncryptionDecryption.encrypt(string(concat('mobilebankingcpb@#%1',$document_Input1/FTBakongWalletRq/TransId,$document_Input1/FTBakongWalletRq/CifNo,$document_Input1/FTBakongWalletRq/FromAccount,$document_Input1/FTBakongWalletRq/ToAccount,$document_Input1/FTBakongWalletRq/WalletNumber,myext:replace(string($document_Input1/FTBakongWalletRq/WalletName),string('&amp;amp;amp;'),string('g'),string('&amp;amp;')),$document_Input1/FTBakongWalletRq/Amount,$document_Input1/FTBakongWalletRq/Currency)),string('secrete')))))=($document_Input1/FTBakongWalletRq/SignData)">
                    &lt;xsl:value-of select="java:_setStringProperty($_TIF_MESSAGE_, 'ValidMessage', 'true')">&lt;/xsl:value-of>
                  &lt;/xsl:when>
                  &lt;xsl:otherwise>
                    &lt;xsl:value-of select="java:_setStringProperty($_TIF_MESSAGE_, 'ValidMessage', 'true')">&lt;/xsl:value-of>
