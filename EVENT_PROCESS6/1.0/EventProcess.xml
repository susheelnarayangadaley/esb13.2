              &lt;xsl:value-of select="''">&lt;/xsl:value-of>
            &lt;/xsl:attribute>
            &lt;ns14:DebitAccount>&lt;xsl:value-of select="&#xd;
    myext:replace(&#xd;
      string($document_Input1/FTBakongWalletRq/FromAccount),&#xd;
      '&amp;amp;(?!amp;|lt;|gt;|quot;|apos;)',&#xd;
