            &lt;/ns14:CreditCurrency>
            &lt;ns14:CreditAmount>
              &lt;xsl:value-of select="$document_Input1/FTBakongWalletRq/Amount">&lt;/xsl:value-of>
            &lt;/ns14:CreditAmount>
            &lt;ns14:ChargesAcctNO>
