            &lt;/activityName>
            &lt;assignReason>
              &lt;xsl:value-of select="''">&lt;/xsl:value-of>
            &lt;/assignReason>
            &lt;dueDate>
              &lt;xsl:value-of select="''">&lt;/xsl:value-of>
