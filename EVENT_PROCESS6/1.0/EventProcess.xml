  "/>&#xd;
&lt;!--
              &lt;xsl:value-of select="myext:replace(string($document_Input1/FTBakongWalletRq/FromAccount),string('&amp;amp;'),string('g'),string('&amp;amp;amp;'))">&lt;/xsl:value-of>-->&lt;/ns14:DebitAccount>
