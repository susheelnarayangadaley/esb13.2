                &lt;/xsl:choose>
              &lt;/xsl:variable>
              &lt;xsl:value-of select="$if1">&lt;/xsl:value-of>
            &lt;/ns14:DebitNarrative>
            &lt;ns14:CreditNarrative>
              &lt;xsl:value-of select="$document_Input1/FTBakongWalletRq/TransId">&lt;/xsl:value-of>
