                      &lt;xsl:value-of select="truncateString:truncate(string(concat($document_Input1/FTBakongWalletRq/Remark,'(',$document_Input1/FTBakongWalletRq/WalletNumber,')')),string('50'))">&lt;/xsl:value-of>
                    &lt;/xsl:when>
                    &lt;xsl:otherwise>
