<?xml version="1.0" encoding="UTF-8"?>
<xsl:stylesheet version="1.0" xmlns:xalan="http://xml.apache.org/xslt" xmlns:datetime="http://exslt.org/dates-and-times" xmlns:math="http://exslt.org/math" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:lxslt="http://xml.apache.org/xslt" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:java="http://xml.apache.org/xslt/java" xmlns:set="http://exslt.org/sets" exclude-result-prefixes="xalan java lxslt" xmlns:ns2="http://www.w3.org/2001/XMLSchema" xmlns:dateConversion="dateConversion" xmlns:decodeKHQR="http://xml.apache.org/xslt/java" xmlns:getAny="http://xml.apache.org/xslt/java" xmlns:getValue="http://xml.apache.org/xslt/java" xmlns:getValueIndex="http://xml.apache.org/xslt/java" xmlns:jsonToOfs="http://xml.apache.org/xslt/java" xmlns:myext="myext" xmlns:ofsToJson="http://xml.apache.org/xslt/java" xmlns:renameJson="http://xml.apache.org/xslt/java" xmlns:renameKeys="http://xml.apache.org/xslt/java" xmlns:strings="strings" xmlns:xmlToJson="http://xml.apache.org/xslt/java" extension-element-prefixes="datetime set math dateConversion decodeKHQR getAny getValue getValueIndex jsonToOfs myext ofsToJson renameJson renameKeys strings xmlToJson">
  <xsl:import href="GLOBAL_FUNCLET_PATH"></xsl:import>
  <xsl:output method="xml" indent="yes" encoding="UTF-8" xalan:indent-amount="2" omit-xml-declaration="no"></xsl:output>
  <xsl:variable name="document" select="/"></xsl:variable>
  <xsl:template match="/">
    <Root>
      <accountBalance>
        <xsl:value-of select="substring-before($_TIF_BODY_TEXT_,'*')"></xsl:value-of>
      </accountBalance>
      <Currency>
        <xsl:value-of select="substring-before(substring-after($_TIF_BODY_TEXT_,'*'),'*')"></xsl:value-of>
      </Currency>
      <status>
        <xsl:value-of select="substring-before(substring-after(substring-after($_TIF_BODY_TEXT_,'*'),'*'),'*')"></xsl:value-of>
      </status>
      <AccountStatusFlag>
        <xsl:value-of select="substring-before(substring-after(substring-after(substring-after($_TIF_BODY_TEXT_,'*'),'*'),'*'),'*')"></xsl:value-of>
      </AccountStatusFlag>
    </Root>
  </xsl:template>
<!--The list of parameters defined by user-->
  <xsl:param name="_TIF_BODY_TEXT_"></xsl:param>
</xsl:stylesheet>