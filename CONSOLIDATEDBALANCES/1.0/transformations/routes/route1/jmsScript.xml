<?xml version="1.0" encoding="UTF-8"?>
<xsl:stylesheet version="1.0" xmlns:xalan="http://xml.apache.org/xslt" xmlns:datetime="http://exslt.org/dates-and-times" xmlns:math="http://exslt.org/math" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:lxslt="http://xml.apache.org/xslt" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:java="http://xml.apache.org/xslt/java" xmlns:set="http://exslt.org/sets" exclude-result-prefixes="xalan java lxslt" xmlns:ns3="http://www.w3.org/2001/XMLSchema" xmlns:ns2="http://www.fiorano.com/services/rest" xmlns:Trim="Trim" xmlns:checkQrExpireYn="http://xml.apache.org/xslt/java" xmlns:dateConversion="dateConversion" xmlns:decodeKHQR="http://xml.apache.org/xslt/java" xmlns:getAny="http://xml.apache.org/xslt/java" xmlns:getValByIndex="http://xml.apache.org/xslt/java" xmlns:getValue="http://xml.apache.org/xslt/java" xmlns:getValueDouble="http://xml.apache.org/xslt/java" xmlns:getValueStr="http://xml.apache.org/xslt/java" xmlns:jsonToOfs="http://xml.apache.org/xslt/java" xmlns:myext="myext" xmlns:obOfsConvert="http://xml.apache.org/xslt/java" xmlns:obOfsResponse="http://xml.apache.org/xslt/java" xmlns:obOfsResponseObjs="http://xml.apache.org/xslt/java" xmlns:ofsConverterRequest="http://xml.apache.org/xslt/java" xmlns:ofsConverterResponse="http://xml.apache.org/xslt/java" xmlns:ofsConverterResponseCode="http://xml.apache.org/xslt/java" xmlns:ofsToJson="http://xml.apache.org/xslt/java" xmlns:renameJson="http://xml.apache.org/xslt/java" xmlns:renameKeys="http://xml.apache.org/xslt/java" xmlns:strings="strings" xmlns:toDecimal="http://xml.apache.org/xslt/java" extension-element-prefixes="datetime set math Trim checkQrExpireYn dateConversion decodeKHQR getAny getValByIndex getValue getValueDouble getValueStr jsonToOfs myext obOfsConvert obOfsResponse obOfsResponseObjs ofsConverterRequest ofsConverterResponse ofsConverterResponseCode ofsToJson renameJson renameKeys strings toDecimal">
  <xsl:import href="GLOBAL_FUNCLET_PATH"></xsl:import>
  <xsl:output method="xml" indent="yes" encoding="UTF-8" xalan:indent-amount="2" omit-xml-declaration="no"></xsl:output>
  <xsl:variable name="document" select="/"></xsl:variable>
  <xsl:variable name="document_executeData__POST__Request" select="document('executeData__POST__Request')"></xsl:variable>
  <xsl:template match="/">
    <Text>
      <xsl:value-of select="'ENQUIRY.SELECT,,'"></xsl:value-of>
      <xsl:value-of select="concat(java:_getStringProperty($_TIF_MESSAGE_, 'user'),'/',java:_getStringProperty($_TIF_MESSAGE_, 'pass'))"></xsl:value-of>
      <xsl:value-of select="','"></xsl:value-of>
      <xsl:value-of select="concat('LOLC.LIST.MOBILE.ACCOUNT,Y.CUSTOMER.ID:EQ=',getValueStr:lolc.utility.JsonValueUtil.getValueStr(string($document_executeData__POST__Request/ns2:Request/Representations/Representation/Element),string('customerId')))"></xsl:value-of>
    </Text>
  </xsl:template>
<!--The list of parameters defined by user-->
  <xsl:param name="_TIF_MESSAGE_"></xsl:param>
<!--The list of Extensions defined by user-->
</xsl:stylesheet>