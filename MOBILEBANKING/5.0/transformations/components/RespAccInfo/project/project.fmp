  <mappermodel:Extensions>
    <mappermodel:Extension language="javascript" name="rounding">
      <mappermodel:Script>function round(value, decimals) {
  return Number(Math.round(value+'e'+decimals)+'e-'+decimals);
}</mappermodel:Script>
      <mappermodel:Function name="round" return="String">
        <mappermodel:Argument datatype="String" name="value"/>
        <mappermodel:Argument datatype="String" name="decimals"/>
      </mappermodel:Function>
    </mappermodel:Extension>
  </mappermodel:Extensions>
