<?xml version="1.0" encoding="UTF-8"?>
<xsl:stylesheet version="1.0" xmlns:xalan="http://xml.apache.org/xslt" xmlns:datetime="http://exslt.org/dates-and-times" xmlns:math="http://exslt.org/math" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:lxslt="http://xml.apache.org/xslt" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:java="http://xml.apache.org/xslt/java" xmlns:set="http://exslt.org/sets" exclude-result-prefixes="xalan java lxslt" xmlns:ns3="http://www.w3.org/2001/XMLSchema" xmlns:ns1="http://schemas.xmlsoap.org/soap/envelope/" xmlns:AppendZero="AppendZero" xmlns:EnDe="http://xml.apache.org/xslt/java" xmlns:MD5Hex="http://xml.apache.org/xslt/java" xmlns:Md5UniCode="http://xml.apache.org/xslt/java" xmlns:Remove="Remove" xmlns:ReplaceText="ReplaceText" xmlns:StringLength="StringLength" xmlns:dateConversion="dateConversion" xmlns:myext="myext" xmlns:replace="replace" xmlns:replaceStr="http://xml.apache.org/xslt/java" xmlns:rounding="rounding" xmlns:sringindex="sringindex" xmlns:strings="strings" xmlns:stringtext="stringtext" xmlns:truncateString="truncateString" extension-element-prefixes="datetime set math AppendZero EnDe MD5Hex Md5UniCode Remove ReplaceText StringLength dateConversion myext replace replaceStr rounding sringindex strings stringtext truncateString">
  <xsl:import href="GLOBAL_FUNCLET_PATH"></xsl:import>
  <xsl:output method="xml" indent="yes" encoding="UTF-8" xalan:indent-amount="2" omit-xml-declaration="no"></xsl:output>
  <xsl:variable name="document" select="/"></xsl:variable>
  <xsl:variable name="document_OUT_PORT" select="document('OUT_PORT')"></xsl:variable>
  <xsl:template match="/">
    <ns1:Envelope>
      <ns1:Body>
        <Response>
          <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
          <xsl:value-of select="java:_getText($_TIF_MESSAGE_)" disable-output-escaping="yes"></xsl:value-of>
          <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
        </Response>
      </ns1:Body>
    </ns1:Envelope>
  </xsl:template>
<!--The list of parameters defined by user-->
  <xsl:param name="_TIF_MESSAGE_"></xsl:param>
</xsl:stylesheet>