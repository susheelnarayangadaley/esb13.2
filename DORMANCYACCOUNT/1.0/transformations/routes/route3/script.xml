<?xml version="1.0" encoding="UTF-8"?>
<xsl:stylesheet version="1.0" xmlns:xalan="http://xml.apache.org/xslt" xmlns:datetime="http://exslt.org/dates-and-times" xmlns:math="http://exslt.org/math" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:lxslt="http://xml.apache.org/xslt" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:java="http://xml.apache.org/xslt/java" xmlns:set="http://exslt.org/sets" exclude-result-prefixes="xalan java lxslt" xmlns:ns3="http://www.w3.org/2001/XMLSchema" xmlns:ns2="http://www.fiorano.com/fesb/activity/DB1/Response" xmlns:dateConversion="dateConversion" xmlns:myext="myext" xmlns:strings="strings" extension-element-prefixes="datetime set math dateConversion myext strings">
  <xsl:import href="GLOBAL_FUNCLET_PATH"></xsl:import>
  <xsl:output method="xml" indent="yes" encoding="UTF-8" xalan:indent-amount="2" omit-xml-declaration="no"></xsl:output>
  <xsl:variable name="document" select="/"></xsl:variable>
  <xsl:template match="/">
    <ns2:root>
      <ns2:responseCode>
        <xsl:value-of select="substring-before($_TIF_BODY_TEXT_,'*')"></xsl:value-of>
      </ns2:responseCode>
      <ns2:responseMsg>
        <xsl:value-of select="substring-before(substring-after($_TIF_BODY_TEXT_,'*'),'*')"></xsl:value-of>
      </ns2:responseMsg>
      <ns2:account>
        <xsl:value-of select="substring-before(substring-after(substring-after($_TIF_BODY_TEXT_,'*'),'*'),'*')"></xsl:value-of>
      </ns2:account>
    </ns2:root>
  </xsl:template>
<!--The list of parameters defined by user-->
  <xsl:param name="_TIF_BODY_TEXT_"></xsl:param>
</xsl:stylesheet>