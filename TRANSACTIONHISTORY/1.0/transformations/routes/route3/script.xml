<?xml version="1.0" encoding="UTF-8"?>
<xsl:stylesheet version="1.0" xmlns:xalan="http://xml.apache.org/xslt" xmlns:datetime="http://exslt.org/dates-and-times" xmlns:math="http://exslt.org/math" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:lxslt="http://xml.apache.org/xslt" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:java="http://xml.apache.org/xslt/java" xmlns:set="http://exslt.org/sets" exclude-result-prefixes="xalan java lxslt" xmlns:ns2="http://www.w3.org/2001/XMLSchema" xmlns:ns3="http://www.fiorano.com/Seylan/TransactionHistoryInquiry" xmlns:ns4="http://www.fiorano.com/services/rest" xmlns:CardWS="CardWS" xmlns:CenturyDateConv="CenturyDateConv" xmlns:CenturyDateConverter="CenturyDateConverter" xmlns:Currency="Currency" xmlns:DateConversion="DateConversion" xmlns:DateTime="DateTime" xmlns:Decimals="Decimals" xmlns:ESB="ESB" xmlns:RateConverter="RateConverter" xmlns:Text="Text" xmlns:UtilityBIll="UtilityBIll" xmlns:dateConversion="dateConversion" xmlns:myext="myext" xmlns:paddzero="paddzero" xmlns:str="str" xmlns:strings="strings" extension-element-prefixes="datetime set math CardWS CenturyDateConv CenturyDateConverter Currency DateConversion DateTime Decimals ESB RateConverter Text UtilityBIll dateConversion myext paddzero str strings">
  <xsl:import href="GLOBAL_FUNCLET_PATH"></xsl:import>
  <xsl:output method="xml" indent="yes" encoding="UTF-8" xalan:indent-amount="2" omit-xml-declaration="no"></xsl:output>
  <xsl:variable name="document" select="/"></xsl:variable>
  <xsl:variable name="document_TransHistory__GET__Request" select="document('TransHistory__GET__Request')"></xsl:variable>
  <xsl:template match="/">
    <ns4:Responses>
      <Response>
        <Representations>
          <Representation>
            <Element>
              <ns3:TransactionHistoryInquiryResponse>
                <ns3:Status>
                  <ns3:Transaction_Reference>
                    <xsl:value-of select="TH_Header/TransRef"></xsl:value-of>
                  </ns3:Transaction_Reference>
                  <ns3:Timestamp>
                    <xsl:value-of select="DateTime:getISOTimestamp()"></xsl:value-of>
                  </ns3:Timestamp>
                  <ns3:Code>
                    <xsl:value-of select="'2060'"></xsl:value-of>
                  </ns3:Code>
                  <ns3:Message>
                    <xsl:value-of select="ESB:getErrorDescription(string('2060'))"></xsl:value-of>
                  </ns3:Message>
                </ns3:Status>
              </ns3:TransactionHistoryInquiryResponse>
            </Element>
          </Representation>
        </Representations>
      </Response>
    </ns4:Responses>
  </xsl:template>
<!--The list of Extensions defined by user-->
</xsl:stylesheet>