<?xml version="1.0" encoding="UTF-8"?>
<xsl:stylesheet version="1.0" xmlns:xalan="http://xml.apache.org/xslt" xmlns:datetime="http://exslt.org/dates-and-times" xmlns:math="http://exslt.org/math" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:lxslt="http://xml.apache.org/xslt" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:java="http://xml.apache.org/xslt/java" xmlns:set="http://exslt.org/sets" exclude-result-prefixes="xalan java lxslt" xmlns:ns4="http://www.fiorano.com/SeylanESB" xmlns:ns5="http://www.w3.org/2001/XMLSchema" xmlns:ns1="http://www.fiorano.com/Seylan/TransactionHistoryInquiry" xmlns:ns2="http://www.fiorano.com/services/rest" xmlns:CEFT_JPAY="CEFT_JPAY" xmlns:CardWS="CardWS" xmlns:CenturyDateConverter="CenturyDateConverter" xmlns:Currency="Currency" xmlns:DateConversion="DateConversion" xmlns:DateTime="DateTime" xmlns:Decimals="Decimals" xmlns:ENIQR="ENIQR" xmlns:ESB="ESB" xmlns:QR="QR" xmlns:RateConverter="RateConverter" xmlns:Text="Text" xmlns:TimeConversion="TimeConversion" xmlns:dateConversion="dateConversion" xmlns:myext="myext" xmlns:paddzero="paddzero" xmlns:str="str" xmlns:strings="strings" extension-element-prefixes="datetime set math CEFT_JPAY CardWS CenturyDateConverter Currency DateConversion DateTime Decimals ENIQR ESB QR RateConverter Text TimeConversion dateConversion myext paddzero str strings">
  <xsl:import href="GLOBAL_FUNCLET_PATH"></xsl:import>
  <xsl:output method="xml" indent="yes" encoding="UTF-8" xalan:indent-amount="2" omit-xml-declaration="no"></xsl:output>
  <xsl:variable name="document" select="/"></xsl:variable>
  <xsl:variable name="document_TransHistory__GET__Request" select="document('TransHistory__GET__Request')"></xsl:variable>
  <xsl:template match="/">
    <ns4:Input>
      <ns4:WSID>
        <xsl:value-of select="ESB:getValueFromLeft(string(java:_getStringProperty($_TIF_MESSAGE_, 'http_WorkstationId')),string(java:_getStringProperty($_TIF_MESSAGE_, 'WorkstationId')),string(null),string(null))"></xsl:value-of>
      </ns4:WSID>
      <ns4:BRNM>
        <xsl:value-of select="ESB:getValueFromLeft(string(java:_getStringProperty($_TIF_MESSAGE_, 'http_InputBranchMne')),string(java:_getStringProperty($_TIF_MESSAGE_, 'InputBranchMne')),string(null),string(null))"></xsl:value-of>
      </ns4:BRNM>
      <ns4:USER>
        <xsl:value-of select="ESB:getValueFromLeft(string(java:_getStringProperty($_TIF_MESSAGE_, 'http_InputUser')),string(java:_getStringProperty($_TIF_MESSAGE_, 'InputUser')),string(null),string(null))"></xsl:value-of>
      </ns4:USER>
      <ns4:APPID>
        <xsl:value-of select="java:_getStringProperty($_TIF_MESSAGE_, 'http_PostingBatch')"></xsl:value-of>
      </ns4:APPID>
      <ns4:APPTYPE>
        <xsl:value-of select="'00'"></xsl:value-of>
      </ns4:APPTYPE>
      <ns4:ACATG>
        <xsl:value-of select="substring(TH_Header/Account_Category,'1','1')"></xsl:value-of>
      </ns4:ACATG>
      <ns4:ACCOUNT>
        <xsl:value-of select="TH_Header/Account_Number"></xsl:value-of>
      </ns4:ACCOUNT>
      <ns4:SDATE>
        <xsl:value-of select="TH_Header/Date_from"></xsl:value-of>
      </ns4:SDATE>
      <ns4:EDATE>
        <xsl:value-of select="TH_Header/Date_to"></xsl:value-of>
      </ns4:EDATE>
      <ns4:RCNTRAN>
        <xsl:value-of select="TH_Header/Number_of_recent_transactions"></xsl:value-of>
      </ns4:RCNTRAN>
      <ns4:TRANDATA></ns4:TRANDATA>
      <ns4:TRNCOUNT></ns4:TRNCOUNT>
      <ns4:RREC></ns4:RREC>
      <ns4:RMSG></ns4:RMSG>
      <ns4:DELAY>
        <xsl:value-of select="'0'"></xsl:value-of>
      </ns4:DELAY>
    </ns4:Input>
  </xsl:template>
<!--The list of parameters defined by user-->
  <xsl:param name="_TIF_MESSAGE_"></xsl:param>
<!--The list of Extensions defined by user-->
</xsl:stylesheet>