<?xml version="1.0" encoding="UTF-8"?>
<xsl:stylesheet version="1.0" xmlns:xalan="http://xml.apache.org/xslt" xmlns:datetime="http://exslt.org/dates-and-times" xmlns:math="http://exslt.org/math" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:lxslt="http://xml.apache.org/xslt" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:java="http://xml.apache.org/xslt/java" xmlns:set="http://exslt.org/sets" exclude-result-prefixes="xalan java lxslt" xmlns:ns4="http://www.w3.org/2001/XMLSchema" xmlns:ns1="http://www.fiorano.com/Seylan/TransactionHistoryInquiry" xmlns:ns2="http://www.fiorano.com/services/rest" xmlns:CEFT_JPAY="CEFT_JPAY" xmlns:CardWS="CardWS" xmlns:CenturyDateConv="CenturyDateConv" xmlns:CenturyDateConverter="CenturyDateConverter" xmlns:Currency="Currency" xmlns:DateConversion="DateConversion" xmlns:DateTime="DateTime" xmlns:Decimals="Decimals" xmlns:ESB="ESB" xmlns:FormatQuery="FormatQuery" xmlns:RateConverter="RateConverter" xmlns:Text="Text" xmlns:TimeConversion="TimeConversion" xmlns:UtilityBIll="UtilityBIll" xmlns:Validation="Validation" xmlns:dateConversion="dateConversion" xmlns:myext="myext" xmlns:paddzero="paddzero" xmlns:str="str" xmlns:strings="strings" extension-element-prefixes="datetime set math CEFT_JPAY CardWS CenturyDateConv CenturyDateConverter Currency DateConversion DateTime Decimals ESB FormatQuery RateConverter Text TimeConversion UtilityBIll Validation dateConversion myext paddzero str strings">
  <xsl:import href="GLOBAL_FUNCLET_PATH"></xsl:import>
  <xsl:output method="xml" indent="yes" encoding="UTF-8" xalan:indent-amount="2" omit-xml-declaration="no"></xsl:output>
  <xsl:variable name="document" select="/"></xsl:variable>
  <xsl:variable name="document_TransHistory__GET__Request" select="document('TransHistory__GET__Request')"></xsl:variable>
  <xsl:template match="/">
    <TH_Header>
      <TransRef>
        <xsl:value-of select="java:_getStringProperty($_TIF_MESSAGE_, 'http_URN')"></xsl:value-of>
        <xsl:value-of select="java:_setStringProperty($_TIF_MESSAGE_, 'ESBX__SYSTEM__USER_DEFINED_DOC_ID', java:_getStringProperty($_TIF_MESSAGE_, 'http_URN'))"></xsl:value-of>
      </TransRef>
      <Account_Category>
        <xsl:variable name="if0">
          <xsl:choose>
            <xsl:when test="contains('INT,EXT',$document_TransHistory__GET__Request/ns2:Request/RequestParameters/AccountCategory)">
              <xsl:value-of select="$document_TransHistory__GET__Request/ns2:Request/RequestParameters/AccountCategory"></xsl:value-of>
            </xsl:when>
            <xsl:otherwise>
              <xsl:value-of select="'EXT'"></xsl:value-of>
            </xsl:otherwise>
          </xsl:choose>
        </xsl:variable>
        <xsl:value-of select="$if0"></xsl:value-of>
      </Account_Category>
      <Account_Number>
        <xsl:value-of select="$document_TransHistory__GET__Request/ns2:Request/RequestParameters/AccountNumber"></xsl:value-of>
      </Account_Number>
      <Date_from>
        <xsl:variable name="if1">
          <xsl:choose>
            <xsl:when test="($document_TransHistory__GET__Request/ns2:Request/RequestParameters/NumberOfTransactions)&gt;('0')">
              <xsl:value-of select="'0'"></xsl:value-of>
            </xsl:when>
            <xsl:when test="($document_TransHistory__GET__Request/ns2:Request/RequestParameters/StartDate)=('')">
              <xsl:value-of select="'0'"></xsl:value-of>
            </xsl:when>
            <xsl:otherwise>
              <xsl:value-of select="CenturyDateConverter:CenturyDateConversion(string($document_TransHistory__GET__Request/ns2:Request/RequestParameters/StartDate),string('Y'))"></xsl:value-of>
            </xsl:otherwise>
          </xsl:choose>
        </xsl:variable>
        <xsl:value-of select="$if1"></xsl:value-of>
      </Date_from>
      <Date_to>
        <xsl:variable name="if2">
          <xsl:choose>
            <xsl:when test="($document_TransHistory__GET__Request/ns2:Request/RequestParameters/NumberOfTransactions)&gt;('0')">
              <xsl:value-of select="'0'"></xsl:value-of>
            </xsl:when>
            <xsl:when test="($document_TransHistory__GET__Request/ns2:Request/RequestParameters/EndDate)=('')">
              <xsl:value-of select="'0'"></xsl:value-of>
            </xsl:when>
            <xsl:otherwise>
              <xsl:value-of select="CenturyDateConverter:CenturyDateConversion(string($document_TransHistory__GET__Request/ns2:Request/RequestParameters/EndDate),string('Y'))"></xsl:value-of>
            </xsl:otherwise>
          </xsl:choose>
        </xsl:variable>
        <xsl:value-of select="$if2"></xsl:value-of>
      </Date_to>
      <Number_of_recent_transactions>
        <xsl:value-of select="ESB:getPreferredValue(string($document_TransHistory__GET__Request/ns2:Request/RequestParameters/NumberOfTransactions),string('0'))"></xsl:value-of>
      </Number_of_recent_transactions>
      <Message>
        <xsl:variable name="if3">
          <xsl:choose>
            <xsl:when test="((ESB:getPreferredValue(string($document_TransHistory__GET__Request/ns2:Request/RequestParameters/NumberOfTransactions),string('0')))=('0') and ((TH_Header/Date_from)=('') or (TH_Header/Date_to)=('')))">
              <xsl:value-of select="'Both Start Date and End Date are required'"></xsl:value-of>
            </xsl:when>
            <xsl:otherwise>
              <xsl:value-of select="''"></xsl:value-of>
            </xsl:otherwise>
          </xsl:choose>
        </xsl:variable>
        <xsl:value-of select="$if3"></xsl:value-of>
      </Message>
    </TH_Header>
  </xsl:template>
<!--The list of parameters defined by user-->
  <xsl:param name="_TIF_MESSAGE_"></xsl:param>
<!--The list of Extensions defined by user-->
</xsl:stylesheet>