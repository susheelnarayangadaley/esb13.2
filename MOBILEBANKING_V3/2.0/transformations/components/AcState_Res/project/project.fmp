            &lt;/xsl:when>&#xD;
                  &lt;xsl:when test=&quot;(./ns26:EACCTIDDR)=('000001558')&quot;>&#xD;
                    &lt;xsl:value-of select=&quot;''&quot;>&lt;/xsl:value-of>&#xD;
                  &lt;/xsl:when>&#xD;
                  &lt;xsl:otherwise>&#xD;
                    &lt;xsl:value-of select=&quot;./ns26:EACCTIDDR&quot;>&lt;/xsl:value-of>&#xD;
                  &lt;/xsl:otherwise>&#xD;
                &lt;/xsl:choose>&#xD;
              &lt;/xsl:variable>&#xD;
              &lt;xsl:value-of select=&quot;$if0&quot;>&lt;/xsl:value-of>&#xD;
           &lt;/DrAcctNo>&#xD;
 &lt;CrAcctName>&#xD;
  &lt;xsl:variable name=&quot;if0&quot;>&#xD;
                &lt;xsl:choose>&#xD;
			&lt;xsl:when test=&quot;starts-with(./ns26:EACCTIDCR,'000001966')&quot;>&#xD;
                    &lt;xsl:value-of select=&quot;''&quot;>&lt;/xsl:value-of>&#xD;
            &lt;/xsl:when>&#xD;
			&lt;xsl:when test=&quot;starts-with(./ns26:EACCTIDCR,'000001578')&quot;>&#xD;
                    &lt;xsl:value-of select=&quot;''&quot;>&lt;/xsl:value-of>&#xD;
            &lt;/xsl:when>&#xD;
			&lt;xsl:when test=&quot;starts-with(./ns26:ETXNDESC,'BKG Outward Transfer')&quot;>&#xD;
                    &#xD;
					  &lt;xsl:value-of select=&quot;concat(./ns26:RVNAME,' &#xD;
					  Bank Name:',./ns26:ReceiverBank)&quot;>&lt;/xsl:value-of>&#xD;
