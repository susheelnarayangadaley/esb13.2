      &lt;CrAcctNo>&#xD;
              &lt;xsl:variable name=&quot;if0&quot;>&#xD;
                &lt;xsl:choose>&#xD;
                  &lt;xsl:when test=&quot;starts-with(./ns26:EACCTIDCR,'USD')&quot;>&#xD;
                    &lt;xsl:value-of select=&quot;''&quot;>&lt;/xsl:value-of>&#xD;
                  &lt;/xsl:when>&#xD;
                  &lt;xsl:when test=&quot;starts-with(./ns26:EACCTIDCR,'000001966')&quot;>&#xD;
                    &lt;xsl:value-of select=&quot;''&quot;>&lt;/xsl:value-of>&#xD;
                  &lt;/xsl:when>&#xD;
				 &lt;xsl:when test=&quot;starts-with(./ns26:EACCTIDCR,'000001578')&quot;>&#xD;
                    &lt;xsl:value-of select=&quot;''&quot;>&lt;/xsl:value-of>&#xD;
				&lt;/xsl:when>&#xD;
                  &lt;xsl:when test=&quot;(./ns26:EACCTIDCR)=('000001558')&quot;>&#xD;
