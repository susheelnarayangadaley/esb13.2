  <mappermodel:UserXSL index="0" node="Output1:0,AccountStmtRp:0,ListTxn:0,[ZERO MANY]:0,TxnDetail:0">&lt;xsl:variable name=&quot;pos&quot; select=&quot;position()&quot;/></mappermodel:UserXSL>
  <mappermodel:UserXSL index="1" node="Output1:0,AccountStmtRp:0,ListTxn:0,[ZERO MANY]:0,TxnDetail:0">&lt;TxnCcy>&#xD;
              &lt;xsl:value-of select=&quot;./ns26:CCY&quot;>&lt;/xsl:value-of>&#xD;
            &lt;/TxnCcy>&#xD;
&lt;Txntype>&#xD;
              &lt;xsl:value-of select=&quot;./ns26:ETXNTYPE&quot;>&lt;/xsl:value-of>&#xD;
            &lt;/Txntype>&#xD;
&lt;TxnContent>&#xD;
&lt;xsl:variable name=&quot;if0&quot;>&#xD;
                &lt;xsl:choose>&#xD;
	 &lt;xsl:when test=&quot;(starts-with(./ns26:ETXNNARR,'AC-'))&quot;>&#xD;
                    &lt;xsl:value-of select=&quot;concat(./ns26:ETXNDESC,' Fee ')&quot;>&lt;/xsl:value-of>&#xD;
                  &lt;/xsl:when>&#xD;
	 &lt;xsl:when test=&quot;(starts-with(./ns26:ETXNNARR,'SVGATE'))&quot;>&#xD;
                    &lt;xsl:value-of select=&quot;concat(./ns26:ETXNDESC,' from Mobile Banking ')&quot;>&lt;/xsl:value-of>&#xD;
                  &lt;/xsl:when>&#xD;
	 &lt;xsl:when test=&quot;(starts-with(./ns26:ETXNDESC,'PP'))&quot;>&#xD;
                    &lt;xsl:value-of select=&quot;concat(./ns26:ETXNNARR,'')&quot;>&lt;/xsl:value-of>&#xD;
                  &lt;/xsl:when>&#xD;
		 &lt;xsl:when test=&quot;(string-length(./ns26:ETXNNARR)!=('0'))&quot;>&#xD;
                    &lt;xsl:value-of select=&quot;concat(./ns26:ETXNNARR,'')&quot;>&lt;/xsl:value-of>&#xD;
                  &lt;/xsl:when>&#xD;
		 &lt;xsl:otherwise>&#xD;
              &lt;xsl:value-of select=&quot;concat(./ns26:ETXNDESC,' ',./ns26:ETXNNARR)&quot;>&lt;/xsl:value-of>&#xD;
			  &#xD;
                  &lt;/xsl:otherwise>&#xD;
                &lt;/xsl:choose>&#xD;
              &lt;/xsl:variable>&#xD;
              &lt;xsl:value-of select=&quot;$if0&quot;>&lt;/xsl:value-of>&#xD;
            &lt;/TxnContent>&#xD;
			&lt;LastId>&#xD;
&lt;xsl:value-of select = &quot;position()&quot; />&#xD;
&lt;/LastId></mappermodel:UserXSL>
  <mappermodel:UserXSL index="2" node="Output1:0,AccountStmtRp:0,ListTxn:0,[ZERO MANY]:0,TxnDetail:0">&lt;TxnAmount>&#xD;
              &lt;xsl:variable name=&quot;if0&quot;>&#xD;
                &lt;xsl:choose>&#xD;
                  &lt;xsl:when test=&quot;(string-length(./ns26:Credit))=('0')&quot;>&#xD;
                    &lt;xsl:value-of select=&quot;./ns26:Debit&quot;>&lt;/xsl:value-of>&#xD;
                  &lt;/xsl:when>&#xD;
                  &lt;xsl:otherwise>&#xD;
                    &lt;xsl:value-of select=&quot;./ns26:Credit&quot;>&lt;/xsl:value-of>&#xD;
                  &lt;/xsl:otherwise>&#xD;
                &lt;/xsl:choose>&#xD;
              &lt;/xsl:variable>&#xD;
              &lt;xsl:value-of select=&quot;$if0&quot;>&lt;/xsl:value-of>&#xD;
            &lt;/TxnAmount>&#xD;
            &lt;TxnDate>&#xD;
 				&lt;xsl:value-of select=&quot;./ns26:ETXNDATE&quot;>&lt;/xsl:value-of>&#xD;
            &lt;/TxnDate>&#xD;
            &lt;TxnRefNo>&#xD;
			 &lt;xsl:variable name=&quot;if0&quot;>&#xD;
                &lt;xsl:choose>&#xD;
                 &lt;xsl:when test=&quot;starts-with(./ns26:ETXNDESC,'BKG Outward Transfer') and string-length(./ns26:TRXHASH)!=('0')&quot;>&#xD;
                   &lt;xsl:value-of select=&quot;./ns26:TRXHASH&quot;>&lt;/xsl:value-of>&#xD;
                  &lt;/xsl:when>&#xD;
				   &lt;xsl:otherwise>&#xD;
              &lt;xsl:value-of select=&quot;./ns26:Reference&quot;>&lt;/xsl:value-of>&#xD;
			   &lt;/xsl:otherwise>&#xD;
                &lt;/xsl:choose>&#xD;
              &lt;/xsl:variable>&#xD;
              &lt;xsl:value-of select=&quot;$if0&quot;>&lt;/xsl:value-of>&#xD;
            &lt;/TxnRefNo>&#xD;
    &lt;DrAcctNo>&#xD;
              &lt;xsl:variable name=&quot;if0&quot;>&#xD;
                &lt;xsl:choose>&#xD;
                  &lt;xsl:when test=&quot;starts-with(./ns26:EACCTIDDR,'USD')&quot;>&#xD;
                    &lt;xsl:value-of select=&quot;''&quot;>&lt;/xsl:value-of>&#xD;
                  &lt;/xsl:when>&#xD;
                  &lt;xsl:when test=&quot;starts-with(./ns26:EACCTIDDR,'000001966')&quot;>&#xD;
                    &lt;xsl:value-of select=&quot;''&quot;>&lt;/xsl:value-of>&#xD;
                  &lt;/xsl:when>&#xD;
			&lt;xsl:when test=&quot;starts-with(./ns26:EACCTIDCR,'000001578')&quot;>&#xD;
