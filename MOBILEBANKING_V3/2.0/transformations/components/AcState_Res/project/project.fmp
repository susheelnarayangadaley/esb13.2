            &lt;/CrAcctNo>&#xD;
&lt;TxnTittle>		&#xD;
&lt;xsl:variable name=&quot;if0&quot;>&#xD;
                &lt;xsl:choose>&#xD;
                  &lt;xsl:when test=&quot;(string(./ns26:ETXNDESC)=('Mobile Banking FT') and string-length(./ns26:Debit)=('0') and string-length(./ns26:EACCTNAMECR)!=('0'))&quot;>&#xD;
                    &lt;xsl:value-of select=&quot;concat('Received From ',./ns26:EACCTNAMEDR)&quot;>&lt;/xsl:value-of>&#xD;
                  &lt;/xsl:when>&#xD;
                  &lt;xsl:when test=&quot;(string(./ns26:ETXNDESC)=('Mobile Banking FT') and string-length(./ns26:Credit)=('0') and string-length(./ns26:EACCTNAMECR)!=('0'))&quot;>&#xD;
                    &lt;xsl:value-of select=&quot;concat('Transfer To ',./ns26:EACCTNAMECR)&quot;>&lt;/xsl:value-of>&#xD;
                  &lt;/xsl:when>&#xD;
                  &lt;xsl:when test=&quot;(string(./ns26:ETXNDESC)=('Mobile Banking FT') and string-length(./ns26:Credit)=('0') and string-length(./ns26:EACCTNAMECR)=('0')  and string(./ns26:ETXNNARR)!=('CBC fee charge#'))&quot;>&#xD;
                    &lt;xsl:value-of select=&quot;'Topup to e-Wallet'&quot;>&lt;/xsl:value-of>&#xD;
                  &lt;/xsl:when>&#xD;
				    &lt;xsl:when test=&quot;(string(./ns26:ETXNDESC)=('Mobile Banking FT') and string-length(./ns26:Credit)=('0') and string-length(./ns26:EACCTNAMECR)=('0') and string(./ns26:ETXNNARR)=('CBC fee charge#'))&quot;>&#xD;
                    &lt;xsl:value-of select=&quot;'CBC Fee Charge'&quot;>&lt;/xsl:value-of>&#xD;
                  &lt;/xsl:when>&#xD;
	    &lt;xsl:when test=&quot;(string-length(./ns26:ETXNDESC)=('0'))&quot;>&#xD;
                    &lt;xsl:value-of select=&quot;concat(./ns26:Description,' ',./ns26:ETXNNARR)&quot;>&lt;/xsl:value-of>&#xD;
                  &lt;/xsl:when>&#xD;
	    &lt;xsl:when test=&quot;(starts-with(./ns26:ETXNNARR,'AC-'))&quot;>&#xD;
                    &lt;xsl:value-of select=&quot;concat(./ns26:ETXNDESC,' Fee ')&quot;>&lt;/xsl:value-of>&#xD;
                  &lt;/xsl:when>&#xD;
	    &lt;xsl:when test=&quot;(string(./ns26:Description)=('VISA Pay Dr') and starts-with(./ns26:ETXNNARR,'SVGATE'))&quot;>&#xD;
                     &lt;xsl:value-of select=&quot;'Credit Card Payment'&quot;>&lt;/xsl:value-of>&#xD;
                  &lt;/xsl:when>&#xD;
	    &lt;xsl:when test=&quot;(string(./ns26:ETXNDESC)=('BKG Outward Transfer'))&quot;>&#xD;
                     &lt;xsl:value-of select=&quot;concat('Transfer to Bakong ',./ns26:RVACCT)&quot;>&lt;/xsl:value-of>&#xD;
                  &lt;/xsl:when>&#xD;
		&lt;xsl:when test=&quot;(string(./ns26:ETXNDESC)=('BKG Inwrd Transfer'))&quot;>&#xD;
                     &lt;xsl:value-of select=&quot;'Cash Deposit from Bakong'&quot;>&lt;/xsl:value-of>&#xD;
                  &lt;/xsl:when>&#xD;
	    &lt;xsl:when test=&quot;(string(./ns26:ETXNDESC)=('Mobile Banking Bills Topup') or (string(./ns26:ETXNDESC)=('PPSolid Wast bill payment')))&quot;>&#xD;
                     &lt;xsl:value-of select=&quot;'Bill Payment'&quot;>&lt;/xsl:value-of>&#xD;
                  &lt;/xsl:when>&#xD;
	    &lt;xsl:when test=&quot;(string(./ns26:Description)=('ATM FtMobile Out') and (string(./ns26:EACCTIDCR)=('000286644') or string(./ns26:EACCTIDCR)=('000286645')))&quot;>&#xD;
		   &lt;xsl:value-of select=&quot;concat('Cash by Code at ',./ns26:ETXNNARR)&quot;>&lt;/xsl:value-of>&#xD;
                  &lt;/xsl:when>&#xD;
	    &lt;xsl:otherwise>&#xD;
&lt;xsl:value-of select=&quot;concat(./ns26:ETXNDESC,' ',./ns26:ETXNNARR)&quot;>&lt;/xsl:value-of>&#xD;
                  &lt;/xsl:otherwise>&#xD;
                &lt;/xsl:choose>&#xD;
              &lt;/xsl:variable>&#xD;
              &lt;xsl:value-of select=&quot;$if0&quot;>&lt;/xsl:value-of>&#xD;
&lt;/TxnTittle>&#xD;
  &lt;TxnValDateTime>&#xD;
  &lt;xsl:value-of select=&quot;./ns26:ETXNTIME&quot;>&lt;/xsl:value-of>&#xD;
            &lt;/TxnValDateTime></mappermodel:UserXSL>
</mappermodel:MapperProject>