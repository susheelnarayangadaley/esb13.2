      </ns2:transactionUniqueNumber>
      <ns2:remittanceTransactionUniqueNumber>
        <xsl:value-of select="substring-before(substring-after(java:com.fiorano.xslt.functions.base64.Base64.getDecodedString($document_fundTransferChannel__POST__Response/ns3:Responses/Response/Representations/Representation/Element),'&quot;transactionUniqueNumber&quot;:&quot;'),'&quot;')"></xsl:value-of>
      </ns2:remittanceTransactionUniqueNumber>
      <ns2:channel>
