      </ns2:toBank>
      <ns2:currency>
        <xsl:value-of select="ns2:root/ns2:currency"></xsl:value-of>
      </ns2:currency>
      <ns2:errorMsg>
        <xsl:value-of select="java:_setStringProperty($_TIF_MESSAGE_, 'FT', contains(java:com.fiorano.xslt.functions.base64.Base64.getDecodedString($document_fundTransferChannel__POST__Response/ns3:Responses/Response/Representations/Representation/Element),'&quot;responseCode&quot;:&quot;000&quot;'))"></xsl:value-of>
        <xsl:value-of select="substring-before(substring-after(java:com.fiorano.xslt.functions.base64.Base64.getDecodedString($document_fundTransferChannel__POST__Response/ns3:Responses/Response/Representations/Representation/Element),'&quot;errorMsg&quot;:&quot;'),'&quot;')"></xsl:value-of>
