        <xsl:value-of select="substring-before(substring-after($document_fundTransferChannel__POST__Response/ns3:Responses/Response/Representations/Representation/Element,'&quot;responseCode\&quot;:\&quot;'),'\')"></xsl:value-of>
      </ns2:responseCode>
