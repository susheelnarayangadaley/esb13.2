<?xml version="1.0" encoding="UTF-8"?>
<xsl:stylesheet version="1.0" xmlns:xalan="http://xml.apache.org/xslt" xmlns:datetime="http://exslt.org/dates-and-times" xmlns:math="http://exslt.org/math" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:lxslt="http://xml.apache.org/xslt" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:java="http://xml.apache.org/xslt/java" xmlns:set="http://exslt.org/sets" exclude-result-prefixes="xalan java lxslt" xmlns:ns1="http://www.w3.org/2001/XMLSchema" xmlns:ns2="http://schemas.xmlsoap.org/soap/envelope/" xmlns:AppendZero="AppendZero" xmlns:MD5Hex="http://xml.apache.org/xslt/java" xmlns:StringLength="StringLength" xmlns:dateConversion="dateConversion" xmlns:multifields="multifields" xmlns:multifieldsstring="multifieldsstring" xmlns:myext="myext" xmlns:mytext="mytext" xmlns:rounding="rounding" xmlns:sringindex="sringindex" xmlns:strings="strings" xmlns:truncateString="truncateString" extension-element-prefixes="datetime set math AppendZero MD5Hex StringLength dateConversion multifields multifieldsstring myext mytext rounding sringindex strings truncateString">
  <xsl:import href="GLOBAL_FUNCLET_PATH"></xsl:import>
  <xsl:output method="xml" indent="yes" encoding="UTF-8" xalan:indent-amount="2" omit-xml-declaration="no"></xsl:output>
  <xsl:variable name="document" select="/"></xsl:variable>
  <xsl:variable name="document_SOAP11_checkAccount_REQUEST" select="document('SOAP11_checkAccount_REQUEST')"></xsl:variable>
  <xsl:template match="/">
    <checkAccount>
      <AccountNo><xsl:value-of select="$document_SOAP11_checkAccount_REQUEST/ns2:Envelope/ns2:Body/Request/checkAccount/AccountNo"></xsl:value-of>
        <xsl:value-of select="java:_setStringProperty($_TIF_MESSAGE_, 'TransactionType', 'checkaccount')"></xsl:value-of>
      </AccountNo>
    </checkAccount>
  </xsl:template>
<!--The list of parameters defined by user-->
  <xsl:param name="_TIF_MESSAGE_"></xsl:param>
</xsl:stylesheet>