<?xml version="1.0" encoding="UTF-8"?>
<xsl:stylesheet version="1.0" xmlns:xalan="http://xml.apache.org/xslt" xmlns:datetime="http://exslt.org/dates-and-times" xmlns:math="http://exslt.org/math" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:lxslt="http://xml.apache.org/xslt" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:java="http://xml.apache.org/xslt/java" xmlns:set="http://exslt.org/sets" exclude-result-prefixes="xalan java lxslt" xmlns:ns1="http://www.w3.org/2001/XMLSchema" xmlns:ns2="http://schemas.xmlsoap.org/soap/envelope/" xmlns:AppendZero="AppendZero" xmlns:MD5Hex="http://xml.apache.org/xslt/java" xmlns:ReplaceText="ReplaceText" xmlns:StringLength="StringLength" xmlns:dateConversion="dateConversion" xmlns:multifields="multifields" xmlns:multifieldsstring="multifieldsstring" xmlns:myext="myext" xmlns:rounding="rounding" xmlns:sringindex="sringindex" xmlns:strings="strings" xmlns:truncateString="truncateString" extension-element-prefixes="datetime set math AppendZero MD5Hex ReplaceText StringLength dateConversion multifields multifieldsstring myext rounding sringindex strings truncateString">
  <xsl:import href="GLOBAL_FUNCLET_PATH"></xsl:import>
  <xsl:output method="text" indent="yes" encoding="UTF-8" xalan:indent-amount="2" omit-xml-declaration="no"></xsl:output>
  <xsl:variable name="document" select="/"></xsl:variable>
  <xsl:variable name="document_SOAP11_khqrincoming_REQUEST" select="document('SOAP11_khqrincoming_REQUEST')"></xsl:variable>
  <xsl:template match="/">
    <khqrin>
      <Amount>
        <xsl:variable name="if0">
          <xsl:choose>
            <xsl:when test="contains($document_SOAP11_khqrincoming_REQUEST/ns2:Envelope/ns2:Body/Request,'&amp;')">
              <xsl:value-of select="myext:replace(string($document_SOAP11_khqrincoming_REQUEST/ns2:Envelope/ns2:Body/Request),string('&amp;'),string('g'),string('&amp;amp;'))"></xsl:value-of>
            </xsl:when>
            <xsl:otherwise>
              <xsl:value-of select="$document_SOAP11_khqrincoming_REQUEST/ns2:Envelope/ns2:Body/Request"></xsl:value-of>
            </xsl:otherwise>
          </xsl:choose>
        </xsl:variable>
        <xsl:value-of select="$if0"></xsl:value-of>
      </Amount>
    </khqrin>
  </xsl:template>
<!--The list of Extensions defined by user-->
  <lxslt:component prefix="myext" functions="replace">
    <lxslt:script lang="javascript"><![CDATA[function compute(expr){
	return eval(expr);
}

function nextMillenium(){
	d = new Date()    //today's date
	mill=new Date(3000, 00, 01, 00, 00, 00)    //Next millennium start date
	diff = mill-d    //difference in milliseconds
	mtg = new String(diff/86400000)    //calculate days and convert to string
	point=mtg.indexOf(".")    //find the decimal point
	days=mtg.substring(0,point)    //get just the whole days
	return "There are only " + days + " days remaining to the start of the next millennium."; 
}

function replace(input, pattern, flags, str){
	return input.replace(new RegExp(pattern, flags), str);
}]]></lxslt:script>
  </lxslt:component>
</xsl:stylesheet>