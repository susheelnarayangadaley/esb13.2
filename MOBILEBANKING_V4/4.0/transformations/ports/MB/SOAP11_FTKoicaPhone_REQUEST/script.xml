<?xml version="1.0" encoding="UTF-8"?>
<xsl:stylesheet version="1.0" xmlns:xalan="http://xml.apache.org/xslt" xmlns:datetime="http://exslt.org/dates-and-times" xmlns:math="http://exslt.org/math" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:lxslt="http://xml.apache.org/xslt" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:java="http://xml.apache.org/xslt/java" xmlns:set="http://exslt.org/sets" exclude-result-prefixes="xalan java lxslt" xmlns:ns4="http://www.w3.org/2001/XMLSchema" xmlns:ns2="http://schemas.xmlsoap.org/soap/envelope/" xmlns:ns1="http://www.fiorano.com/MB/CPBank" xmlns:AppendZero="AppendZero" xmlns:MD5Hex="http://xml.apache.org/xslt/java" xmlns:dateConversion="dateConversion" xmlns:multifields="multifields" xmlns:multifieldsstring="multifieldsstring" xmlns:myext="myext" xmlns:mytext="mytext" xmlns:rounding="rounding" xmlns:sringindex="sringindex" xmlns:strings="strings" extension-element-prefixes="datetime set math AppendZero MD5Hex dateConversion multifields multifieldsstring myext mytext rounding sringindex strings">
  <xsl:import href="GLOBAL_FUNCLET_PATH"></xsl:import>
  <xsl:output method="xml" indent="yes" encoding="UTF-8" xalan:indent-amount="2" omit-xml-declaration="no"></xsl:output>
  <xsl:variable name="document" select="/"></xsl:variable>
  <xsl:variable name="document_SOAP11_FTKoicaPhone_REQUEST" select="document('SOAP11_FTKoicaPhone_REQUEST')"></xsl:variable>
  <xsl:template match="/">
    <Root>
      <SetValue>
        <xsl:value-of select="java:_setStringProperty($_TIF_MESSAGE_, 'TransactionType', 'FTKoicaPhone')"></xsl:value-of>
      </SetValue>
      <SignData>
        <xsl:variable name="if0">
          <xsl:choose>
            <xsl:when test="(MD5Hex:md5hashing.MD5Hash.getMD5HexencodedString(string(concat('mobilebankingcpb@#%1',$document_SOAP11_FTKoicaPhone_REQUEST/ns2:Envelope/ns2:Body/ns1:FTKoicaPhoneRq/ns1:TransId,$document_SOAP11_FTKoicaPhone_REQUEST/ns2:Envelope/ns2:Body/ns1:FTKoicaPhoneRq/ns1:CifNo,$document_SOAP11_FTKoicaPhone_REQUEST/ns2:Envelope/ns2:Body/ns1:FTKoicaPhoneRq/ns1:FromAccount,$document_SOAP11_FTKoicaPhone_REQUEST/ns2:Envelope/ns2:Body/ns1:FTKoicaPhoneRq/ns1:ToAccount,$document_SOAP11_FTKoicaPhone_REQUEST/ns2:Envelope/ns2:Body/ns1:FTKoicaPhoneRq/ns1:BeneficiaryPhone,$document_SOAP11_FTKoicaPhone_REQUEST/ns2:Envelope/ns2:Body/ns1:FTKoicaPhoneRq/ns1:Amount,$document_SOAP11_FTKoicaPhone_REQUEST/ns2:Envelope/ns2:Body/ns1:FTKoicaPhoneRq/ns1:Currency))))=($document_SOAP11_FTKoicaPhone_REQUEST/ns2:Envelope/ns2:Body/ns1:FTKoicaPhoneRq/ns1:SignData)">
              <xsl:value-of select="java:_setStringProperty($_TIF_MESSAGE_, 'ValidMessage', 'true')"></xsl:value-of>
            </xsl:when>
            <xsl:otherwise>
              <xsl:value-of select="java:_setStringProperty($_TIF_MESSAGE_, 'ValidMessage', 'false')"></xsl:value-of>
            </xsl:otherwise>
          </xsl:choose>
        </xsl:variable>
        <xsl:value-of select="$if0"></xsl:value-of>
      </SignData>
    </Root>
  </xsl:template>
<!--The list of parameters defined by user-->
  <xsl:param name="_TIF_MESSAGE_"></xsl:param>
<!--The list of Extensions defined by user-->
</xsl:stylesheet>