<?xml version="1.0" encoding="UTF-8"?>
<xsl:stylesheet version="1.0" xmlns:xalan="http://xml.apache.org/xslt" xmlns:datetime="http://exslt.org/dates-and-times" xmlns:math="http://exslt.org/math" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:lxslt="http://xml.apache.org/xslt" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:java="http://xml.apache.org/xslt/java" xmlns:set="http://exslt.org/sets" exclude-result-prefixes="xalan java lxslt" xmlns:ns1="http://www.w3.org/2001/XMLSchema" xmlns:Trim="Trim" xmlns:dateConversion="dateConversion" xmlns:decodeKHQR="http://xml.apache.org/xslt/java" xmlns:getValue="http://xml.apache.org/xslt/java" xmlns:getValueByIndex="http://xml.apache.org/xslt/java" xmlns:getValueDouble="http://xml.apache.org/xslt/java" xmlns:getValueStr="http://xml.apache.org/xslt/java" xmlns:jsonToOfs="http://xml.apache.org/xslt/java" xmlns:myext="myext" xmlns:obOfsConvert="http://xml.apache.org/xslt/java" xmlns:obOfsResponse="http://xml.apache.org/xslt/java" xmlns:obOfsResponseObjs="http://xml.apache.org/xslt/java" xmlns:ofsConverterRequest="http://xml.apache.org/xslt/java" xmlns:ofsConverterResponse="http://xml.apache.org/xslt/java" xmlns:ofsConverterResponseCode="http://xml.apache.org/xslt/java" xmlns:ofsToJson="http://xml.apache.org/xslt/java" xmlns:renameKeys="http://xml.apache.org/xslt/java" xmlns:strings="strings" xmlns:toDecimal="http://xml.apache.org/xslt/java" extension-element-prefixes="datetime set math Trim dateConversion decodeKHQR getValue getValueByIndex getValueDouble getValueStr jsonToOfs myext obOfsConvert obOfsResponse obOfsResponseObjs ofsConverterRequest ofsConverterResponse ofsConverterResponseCode ofsToJson renameKeys strings toDecimal">
  <xsl:import href="GLOBAL_FUNCLET_PATH"></xsl:import>
  <xsl:output method="xml" indent="yes" encoding="UTF-8" xalan:indent-amount="2" omit-xml-declaration="no"></xsl:output>
  <xsl:variable name="document" select="/"></xsl:variable>
  <xsl:variable name="document_OUT_PORT" select="document('OUT_PORT')"></xsl:variable>
  <xsl:template match="/">
    <root>
      <response_code>
        <xsl:value-of select="'200'"></xsl:value-of>
      </response_code>
      <response_msg>
        <xsl:value-of select="'Success'"></xsl:value-of>
      </response_msg>
      <savingaccount>
        <xsl:attribute name="class">
          <xsl:value-of select="'array'"></xsl:value-of>
        </xsl:attribute>
        <xsl:for-each select="$document_OUT_PORT/root/Record">
          <Element>
            <account>
              <xsl:value-of select="./ACCOUNT"></xsl:value-of>
            </account>
            <currency>
              <xsl:value-of select="./CURRENCY"></xsl:value-of>
            </currency>
            <accType>
              <xsl:value-of select="./ACC.TYPE"></xsl:value-of>
            </accType>
            <accountStatus>
              <xsl:value-of select="./ACC.STATUS.FLAG"></xsl:value-of>
            </accountStatus>
          </Element>
        </xsl:for-each>
      </savingaccount>
    </root>
  </xsl:template>
</xsl:stylesheet>