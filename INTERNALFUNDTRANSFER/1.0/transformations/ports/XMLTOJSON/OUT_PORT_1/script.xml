<?xml version="1.0" encoding="UTF-8"?>
<xsl:stylesheet version="1.0" xmlns:xalan="http://xml.apache.org/xslt" xmlns:datetime="http://exslt.org/dates-and-times" xmlns:math="http://exslt.org/math" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:lxslt="http://xml.apache.org/xslt" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:java="http://xml.apache.org/xslt/java" xmlns:set="http://exslt.org/sets" exclude-result-prefixes="xalan java lxslt" xmlns:ns2="http://www.w3.org/2001/XMLSchema" xmlns:dateConversion="dateConversion" xmlns:myext="myext" xmlns:strings="strings" extension-element-prefixes="datetime set math dateConversion myext strings">
  <xsl:import href="GLOBAL_FUNCLET_PATH"></xsl:import>
  <xsl:output method="xml" indent="yes" encoding="UTF-8" xalan:indent-amount="2" omit-xml-declaration="no"></xsl:output>
  <xsl:variable name="document" select="/"></xsl:variable>
  <xsl:template match="/">
    <AccountDetails>
      <currencyType>
        <xsl:value-of select="AccountDetails/currencyType"></xsl:value-of>
      </currencyType>
      <transactionAmount>
        <xsl:value-of select="AccountDetails/transactionAmount"></xsl:value-of>
      </transactionAmount>
      <payerName>
        <xsl:value-of select="AccountDetails/payerName"></xsl:value-of>
      </payerName>
      <fromAccount>
        <xsl:value-of select="AccountDetails/fromAccount"></xsl:value-of>
      </fromAccount>
      <fromCurrencyType>
        <xsl:value-of select="AccountDetails/fromCurrencyType"></xsl:value-of>
      </fromCurrencyType>
      <payeeName>
        <xsl:value-of select="AccountDetails/payeeName"></xsl:value-of>
      </payeeName>
      <toAccount>
        <xsl:value-of select="AccountDetails/toAccount"></xsl:value-of>
      </toAccount>
      <toCurrencyType>
        <xsl:value-of select="AccountDetails/toCurrencyType"></xsl:value-of>
      </toCurrencyType>
      <transactionReference>
        <xsl:value-of select="AccountDetails/transactionReference"></xsl:value-of>
      </transactionReference>
      <transactionDescription>
        <xsl:value-of select="AccountDetails/transactionDescription"></xsl:value-of>
      </transactionDescription>
      <channel>
        <xsl:value-of select="AccountDetails/channel"></xsl:value-of>
      </channel>
      <chatid>
        <xsl:value-of select="java:_setStringProperty($_TIF_MESSAGE_, 'MACC', (contains(AccountDetails/fromAccount,'73130740137001') or contains(AccountDetails/fromAccount,'73130740137002') or contains(AccountDetails/fromAccount,'73132076975001')))"></xsl:value-of>
      </chatid>
    </AccountDetails>
  </xsl:template>
<!--The list of parameters defined by user-->
  <xsl:param name="_TIF_MESSAGE_"></xsl:param>
</xsl:stylesheet>