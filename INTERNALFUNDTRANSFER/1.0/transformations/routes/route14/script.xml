<?xml version="1.0" encoding="UTF-8"?>
<xsl:stylesheet version="1.0" xmlns:xalan="http://xml.apache.org/xslt" xmlns:datetime="http://exslt.org/dates-and-times" xmlns:math="http://exslt.org/math" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:lxslt="http://xml.apache.org/xslt" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:java="http://xml.apache.org/xslt/java" xmlns:set="http://exslt.org/sets" exclude-result-prefixes="xalan java lxslt" xmlns:ns2="http://www.fiorano.com/fesb/activity/Bill_Payment/Request" xmlns:ns3="http://www.w3.org/2001/XMLSchema" xmlns:dateConversion="dateConversion" xmlns:myext="myext" xmlns:strings="strings" extension-element-prefixes="datetime set math dateConversion myext strings">
  <xsl:import href="GLOBAL_FUNCLET_PATH"></xsl:import>
  <xsl:output method="xml" indent="yes" encoding="UTF-8" xalan:indent-amount="2" omit-xml-declaration="no"></xsl:output>
  <xsl:variable name="document" select="/"></xsl:variable>
  <xsl:template match="/">
    <ns2:SQL_CFG_1>
      <ns2:UpdateFT>
        <ns2:json_response>
          <xsl:value-of select="java:_getText($_TIF_MESSAGE_)"></xsl:value-of>
        </ns2:json_response>
        <ns2:udate_date>
          <xsl:value-of select="substring(datetime:dateTime(),'0','20')"></xsl:value-of>
        </ns2:udate_date>
        <ns2:wc_iPayref>
          <xsl:value-of select="AccountDetails/transactionReference"></xsl:value-of>
        </ns2:wc_iPayref>
      </ns2:UpdateFT>
    </ns2:SQL_CFG_1>
  </xsl:template>
<!--The list of parameters defined by user-->
  <xsl:param name="_TIF_MESSAGE_"></xsl:param>
</xsl:stylesheet>